# Copy to .env and adjust. Used when running `npm run dev` on the host (not inside Docker).

# Auth: session cookie; production uses __Host- prefix + Strict cookies (see src/lib/auth/session.js)
# AUTH_SECRET=  # min 32 chars, e.g. openssl rand -base64 32

# Public site URL (optional, for calendar UID host in .ics and invite links in emails)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Transactional email (Resend — https://resend.com). Verify your domain, then use e.g. no-reply@yourdomain.com
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=no-reply@yourdomain.com
# EMAIL_FROM_NAME=FleetShare

# Cron: POST /api/cron/reservation-push-reminders with Authorization: Bearer <CRON_SECRET>
# Requires FIREBASE_SERVICE_ACCOUNT_JSON or GOOGLE_APPLICATION_CREDENTIALS for FCM.
# CRON_SECRET=

# Local prod build over HTTP: set to 1 to omit HSTS (avoid browser sticking to HTTPS on localhost)
# DISABLE_HSTS=1

# Licence validation AI (must match your validator container port/path)
AI_VERIFICATION_URL=http://localhost:8080
AI_VERIFY_PATH=/validate
# If the validator returns 422, try: AI_VERIFY_FORM_FIELD=image
# AI_VERIFY_FORM_FIELD=file

# Help-Bot (FleetStream / your chat service on the host)
HELPBOT_URL=http://localhost:8501

# Database (local Postgres or Docker db port 5432)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/company_car_sharing?schema=public
