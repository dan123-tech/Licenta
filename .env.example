# Database (PostgreSQL)
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/company_car_sharing?schema=public"

# Auth – used to sign session/JWT tokens (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-at-least-32-chars-long"

# Optional: base URL of the app (for invite emails, etc.)
# NEXTAUTH_URL="http://localhost:3000"
