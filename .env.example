# Database (PostgreSQL)
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/company_car_sharing?schema=public"

# Auth – used to sign session and encrypt stored credentials (required; at least 16 chars)
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-at-least-32-chars-long"

# Optional: base URL of the app (for invite emails, etc.)
# NEXTAUTH_URL="http://localhost:3000"

# Optional: Firebase Auth for Layer 1 (Users) when Database Settings → Users = Firebase
# Use one of:
#   GOOGLE_APPLICATION_CREDENTIALS="path/to/firebase-service-account.json"
#   FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'  (entire JSON as one line)
