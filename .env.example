# Copy to .env and adjust. Used when running `npm run dev` on the host (not inside Docker).

# Auth: REQUIRED for login — session cookie signing. Min 32 characters or login returns 503.
# Generate: openssl rand -base64 32
# AUTH_SECRET=paste-a-long-random-string-at-least-32-chars-here

# Public site URL (optional, for calendar UID host in .ics and invite links in emails)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# OpenAPI base URL (defaults to http://localhost:3000). Match public URL when using a tunnel / prod.
# NEXTAUTH_URL=http://localhost:3000

# From address (required for any email provider)
# EMAIL_FROM=no-reply@yourcompany.com
# EMAIL_FROM_NAME=FleetShare

# --- Email: company SMTP (used first if SMTP_HOST or SMTP_URL is set) ---
# Example Office 365 / Exchange Online:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=no-reply@yourcompany.com
# SMTP_PASSWORD=app-or-mailbox-password
# Or one line:
# SMTP_URL=smtps://user:password@smtp.office365.com:587
# Internal relay with self-signed TLS (dev only): SMTP_TLS_REJECT_UNAUTHORIZED=0

# --- Email: Resend (https://resend.com) — used only if SMTP is not configured ---
# RESEND_API_KEY=re_xxxxxxxx

# Cron: POST /api/cron/reservation-push-reminders with Authorization: Bearer <CRON_SECRET>
# Requires FIREBASE_SERVICE_ACCOUNT_JSON or GOOGLE_APPLICATION_CREDENTIALS for FCM.
# CRON_SECRET=

# Local prod build over HTTP: set to 1 to omit HSTS (avoid browser sticking to HTTPS on localhost)
# DISABLE_HSTS=1

# Driving licence AI: admins can set Google Gemini per company in Dashboard → Company.
# Fallback external validator (used when no company Gemini key) — Docker Compose sets
# host.docker.internal:8080 for the app container; on the host use localhost:8080.
# Optional one-step install (clones repo next to this project): ./install.sh --ai-validator
# Source & API docs: https://github.com/dan123-tech/AI_driving-licence
AI_VERIFICATION_URL=http://localhost:8080
# Optional default Gemini model when using company API keys (override per deployment)
# GEMINI_MODEL=gemini-2.0-flash
AI_VERIFY_PATH=/validate
# If the validator returns 422, try: AI_VERIFY_FORM_FIELD=image
# AI_VERIFY_FORM_FIELD=file

# Help-Bot (FleetStream / your chat service on the host)
HELPBOT_URL=http://localhost:8501

# Database (local Postgres or Docker db port 5432)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/company_car_sharing?schema=public
