<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true"
    android:padding="16dp">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Statistics" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/on_surface" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/stat_download"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Download"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" android:text="Last 30 days / this month" android:textSize="14sp" android:textColor="@color/on_surface_variant" />
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                <TextView android:id="@+id/statActiveLabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Active reservations" android:textSize="14sp" android:textColor="@color/on_surface_variant" />
                <TextView android:id="@+id/statActive" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/accent" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                <TextView android:id="@+id/statKmLabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Total km this month" android:textSize="14sp" android:textColor="@color/on_surface_variant" />
                <TextView android:id="@+id/statKm" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/on_surface" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                <TextView android:id="@+id/statFuelLabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Estimated fuel cost (this month)" android:textSize="14sp" android:textColor="@color/on_surface_variant" />
                <TextView android:id="@+id/statFuel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/on_surface" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="20dp" android:text="Efficiency leaderboard" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/on_surface" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:text="By estimated fuel cost (completed reservations)" android:textSize="12sp" android:textColor="@color/on_surface_variant" />
        <LinearLayout android:id="@+id/statLeaderboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp" />
        <TextView android:id="@+id/statLoading" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:text="Loading…" android:textColor="@color/on_surface_variant" />
        <View android:layout_width="match_parent" android:layout_height="24dp" />
    </LinearLayout>
</ScrollView>
