<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="200dp"
    android:background="?attr/colorPrimary"
    android:gravity="center_horizontal|bottom"
    android:orientation="vertical"
    android:padding="16dp">
    <ImageView
        android:id="@+id/nav_header_avatar"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="User photo"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_person_circle" />
    <TextView
        android:id="@+id/nav_header_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="User name"
        android:textColor="@color/on_primary"
        android:textSize="18sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/nav_header_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0.9"
        android:gravity="center"
        android:text=""
        android:textColor="@color/on_primary"
        android:textSize="14sp" />
    <TextView
        android:id="@+id/nav_header_join_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:alpha="0.85"
        android:gravity="center"
        android:text=""
        android:textColor="@color/on_primary"
        android:textSize="13sp" />
</LinearLayout>
